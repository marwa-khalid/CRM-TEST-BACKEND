# Local development environment for CRM-TEST-BACKEND.
# NOTE: this file is git-ignored (.env.*) and only used when you run this backend
# locally. In production (Railway) set the equivalent vars in the dashboard;
# the code defaults to Secure + SameSite=None so cross-site/proxied auth works.

# Frontend origin — used for CORS and for building links in emails.
FRONTEND_URL=http://localhost:5174

# Local dev cookie: must NOT be Secure (a Secure cookie is dropped over
# http://localhost) and uses Lax (same-site localhost).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
